rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    match /studentProfiles/{userId} {
      allow create, read, update: if signedIn() && request.auth.uid == userId;
    }

    match /teacherProfiles/{userId} {
      allow create, read, update: if signedIn() && request.auth.uid == userId;
    }

    match /admissionApplications/{applicationId} {
      // Public create is useful for admission enquiry forms. For production, restrict or validate fields as needed.
      allow create: if true;
      allow read, update, delete: if signedIn();
    }
  }
}
